# Client Environment Variables (Example for Vercel/Local)

# The base URL of your backend API.
# In local development using Vite proxy, this might not be strictly needed,
# but for production on Vercel, it MUST point to your Render/Heroku API URL.
VITE_API_URL=https://skillbridge-api.onrender.com

# Stripe Publishable Key (Safe to expose to the client)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key
